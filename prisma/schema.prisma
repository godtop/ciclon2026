generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CodigoDescuento {
  id            Int            @id @default(autoincrement())
  codigo        String         @unique
  tipo          String         // 'porcentaje' o 'montoFijo'
  porcentaje    Int?           // solo si tipo = 'porcentaje'
  montoFijo     Int?           // solo si tipo = 'montoFijo'
  usosMaximos   Int
  usosActuales  Int           @default(0)
  activo        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  inscripciones Inscripcion[]
}

model Inscripcion {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Carrera
  carrera String
  remera  String
  talle   String?
  monto   Int

  // Descuento
  codigoDescuentoId Int?
  codigoDescuento   CodigoDescuento? @relation(fields: [codigoDescuentoId], references: [id])
  montoOriginal     Int

  // Datos personales
  nombre          String
  apellido        String
  sexo            String
  edad            Int
  dni             String
  fechaNacimiento DateTime?

  // Contacto
  codpais   String @default("54")
  codarea   String
  telefono  String
  email     String
  ciudad    String
  domicilio String

  // Comprobante de pago
  comprobanteUrl      String
  comprobantePublicId String

  // Firma digital (imagen PNG en base64, ej: "data:image/png;base64,iVBOR...")
  firmaBase64 String @default("0123456789")

  // Estado
  estado String @default("pendiente")
}
