generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Inscripcion {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Carrera
  carrera String
  remera  String
  talle   String?
  monto   Int

  // Datos personales
  nombre          String
  apellido        String
  sexo            String
  edad            Int
  dni             String
  fechaNacimiento DateTime?

  // Contacto
  codpais   String @default("54")
  codarea   String
  telefono  String
  email     String
  ciudad    String
  domicilio String

  // Comprobante de pago
  comprobanteUrl      String
  comprobantePublicId String

  // Firma digital (imagen PNG en base64, ej: "data:image/png;base64,iVBOR...")
  firmaBase64 String @default("0123456789")

  // Estado
  estado String @default("pendiente")
}
